generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  LAWYER
  ADMIN
}

enum FirmType {
  FULL_SERVICE
  BOUTIQUE
  MID_SIZE
  REGIONAL
}

enum LawyerRole {
  PARTNER
  OF_COUNSEL
  ASSOCIATE
  COUNSEL
  OTHER
}

enum RankingPublisher {
  CHAMBERS
  LEGAL500
  BENCHMARK_LITIGATION
  ASIALAW
}

enum LawyerRankingCategory {
  LEADING
  RECOMMENDED
  UP_AND_COMING
  STAR
  RECOGNISED
}

enum TargetType {
  FIRM
  LAWYER
}

enum MatterType {
  LITIGATION
  ARBITRATION
  REGULATORY
  TRANSACTIONAL
  ADVISORY
  IP
  EMPLOYMENT
  OTHER
}

enum EngagementOutcome {
  WON
  LOST
  SETTLED
  ONGOING
  COMPLETED
  OTHER
}

enum BenchmarkRole {
  PARTNER
  OF_COUNSEL
  ASSOCIATE
  PARALEGAL
}

enum BenchmarkSource {
  ACTUAL
  PROPOSED
  MARKET
}

// ─── Auth / Users ────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  role      UserRole  @default(LAWYER)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  internalRatings    InternalRating[]
  recommendations    Recommendation[]
  engagements        Engagement[]
  relationshipNotes  RelationshipNote[]
  costBenchmarks     CostBenchmark[]
  preference         UserPreference?

  @@map("users")
}

// ─── Reference Data ──────────────────────────────────────────────────────────

model PracticeArea {
  id        String        @id @default(cuid())
  name      String        @unique
  slug      String        @unique
  parentId  String?       @map("parent_id")
  parent    PracticeArea? @relation("PracticeAreaHierarchy", fields: [parentId], references: [id])
  children  PracticeArea[] @relation("PracticeAreaHierarchy")
  createdAt DateTime      @default(now()) @map("created_at")

  firmPracticeAreas   FirmPracticeArea[]
  lawyerPracticeAreas LawyerPracticeArea[]
  firmRankings        FirmRanking[]
  lawyerRankings      LawyerRanking[]
  recommendations     Recommendation[]
  costBenchmarks      CostBenchmark[]

  @@map("practice_areas")
}

model Jurisdiction {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String
  region    String   // APAC, EMEA, AMERICAS, GLOBAL
  createdAt DateTime @default(now()) @map("created_at")

  firmPracticeAreas   FirmPracticeArea[]
  lawyerPracticeAreas LawyerPracticeArea[]
  firmRankings        FirmRanking[]
  lawyerRankings      LawyerRanking[]
  engagements         Engagement[]
  costBenchmarks      CostBenchmark[]

  @@map("jurisdictions")
}

// ─── Firms ───────────────────────────────────────────────────────────────────

model Firm {
  id           String    @id @default(cuid())
  name         String
  shortName    String?   @map("short_name")
  country      String
  city         String
  website      String?
  firmType     FirmType  @default(FULL_SERVICE) @map("firm_type")
  headcount    Int?
  foundedYear  Int?      @map("founded_year")
  parentFirmId String?   @map("parent_firm_id")
  parentFirm   Firm?     @relation("FirmSpinOffs", fields: [parentFirmId], references: [id])
  spinOffs     Firm[]    @relation("FirmSpinOffs")
  isActive     Boolean   @default(true) @map("is_active")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  firmLawyers     FirmLawyer[]
  practiceAreas   FirmPracticeArea[]
  rankings        FirmRanking[]
  internalRatings InternalRating[]
  recommendations Recommendation[]
  engagements     Engagement[]
  relationshipNotes RelationshipNote[]
  costBenchmarks  CostBenchmark[]

  @@map("firms")
}

// ─── Lawyers ─────────────────────────────────────────────────────────────────

model Lawyer {
  id                String    @id @default(cuid())
  name              String
  email             String?
  title             String?
  qualificationYear Int?      @map("qualification_year")
  barAdmissions     String?   @map("bar_admissions")
  bio               String?
  linkedInUrl       String?   @map("linkedin_url")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  firmLawyers     FirmLawyer[]
  practiceAreas   LawyerPracticeArea[]
  rankings        LawyerRanking[]
  internalRatings InternalRating[]
  recommendations Recommendation[]
  engagements     Engagement[]
  relationshipNotes RelationshipNote[]
  costBenchmarks  CostBenchmark[]

  @@map("lawyers")
}

// ─── Join Tables ─────────────────────────────────────────────────────────────

model FirmLawyer {
  id        String     @id @default(cuid())
  firmId    String     @map("firm_id")
  firm      Firm       @relation(fields: [firmId], references: [id])
  lawyerId  String     @map("lawyer_id")
  lawyer    Lawyer     @relation(fields: [lawyerId], references: [id])
  role      LawyerRole @default(PARTNER)
  startDate DateTime?  @map("start_date")
  endDate   DateTime?  @map("end_date")
  isCurrent Boolean    @default(true) @map("is_current")
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@unique([firmId, lawyerId, startDate])
  @@map("firm_lawyers")
}

model FirmPracticeArea {
  id             String       @id @default(cuid())
  firmId         String       @map("firm_id")
  firm           Firm         @relation(fields: [firmId], references: [id])
  practiceAreaId String       @map("practice_area_id")
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId String?      @map("jurisdiction_id")
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([firmId, practiceAreaId, jurisdictionId])
  @@map("firm_practice_areas")
}

model LawyerPracticeArea {
  id             String       @id @default(cuid())
  lawyerId       String       @map("lawyer_id")
  lawyer         Lawyer       @relation(fields: [lawyerId], references: [id])
  practiceAreaId String       @map("practice_area_id")
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId String?      @map("jurisdiction_id")
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([lawyerId, practiceAreaId, jurisdictionId])
  @@map("lawyer_practice_areas")
}

// ─── Rankings ────────────────────────────────────────────────────────────────

model RankingSource {
  id           String           @id @default(cuid())
  name         String           @unique
  slug         String           @unique
  publisher    RankingPublisher
  editionYear  Int              @map("edition_year")
  url          String?
  createdAt    DateTime         @default(now()) @map("created_at")

  firmRankings   FirmRanking[]
  lawyerRankings LawyerRanking[]

  @@unique([publisher, editionYear])
  @@map("ranking_sources")
}

model FirmRanking {
  id               String        @id @default(cuid())
  firmId           String        @map("firm_id")
  firm             Firm          @relation(fields: [firmId], references: [id])
  rankingSourceId  String        @map("ranking_source_id")
  rankingSource    RankingSource @relation(fields: [rankingSourceId], references: [id])
  practiceAreaId   String        @map("practice_area_id")
  practiceArea     PracticeArea  @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId   String        @map("jurisdiction_id")
  jurisdiction     Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  band             Int?          // Chambers 1-6
  tier             Int?          // Legal500 1-5
  starRating       Int?          @map("star_rating") // Benchmark 1-5
  editorialExcerpt String?      @map("editorial_excerpt")
  url              String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([firmId, rankingSourceId, practiceAreaId, jurisdictionId])
  @@map("firm_rankings")
}

model LawyerRanking {
  id               String                @id @default(cuid())
  lawyerId         String                @map("lawyer_id")
  lawyer           Lawyer                @relation(fields: [lawyerId], references: [id])
  rankingSourceId  String                @map("ranking_source_id")
  rankingSource    RankingSource         @relation(fields: [rankingSourceId], references: [id])
  practiceAreaId   String                @map("practice_area_id")
  practiceArea     PracticeArea          @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId   String                @map("jurisdiction_id")
  jurisdiction     Jurisdiction          @relation(fields: [jurisdictionId], references: [id])
  category         LawyerRankingCategory
  editorialExcerpt String?              @map("editorial_excerpt")
  url              String?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@unique([lawyerId, rankingSourceId, practiceAreaId, jurisdictionId])
  @@map("lawyer_rankings")
}

// ─── Internal Insights ──────────────────────────────────────────────────────

model InternalRating {
  id                      String     @id @default(cuid())
  targetType              TargetType @map("target_type")
  firmId                  String?    @map("firm_id")
  firm                    Firm?      @relation(fields: [firmId], references: [id])
  lawyerId                String?    @map("lawyer_id")
  lawyer                  Lawyer?    @relation(fields: [lawyerId], references: [id])
  ratedById               String     @map("rated_by_id")
  ratedBy                 User       @relation(fields: [ratedById], references: [id])
  responsiveness          Int        // 1-5
  quality                 Int        // 1-5
  commercialAwareness     Int        @map("commercial_awareness") // 1-5
  value                   Int        // 1-5
  subjectMatterExpertise  Int        @map("subject_matter_expertise") // 1-5
  overallScore            Float      @map("overall_score") // computed weighted avg
  comment                 String?
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")

  @@map("internal_ratings")
}

model Recommendation {
  id              String       @id @default(cuid())
  targetType      TargetType   @map("target_type")
  firmId          String?      @map("firm_id")
  firm            Firm?        @relation(fields: [firmId], references: [id])
  lawyerId        String?      @map("lawyer_id")
  lawyer          Lawyer?      @relation(fields: [lawyerId], references: [id])
  recommenderId   String       @map("recommender_id")
  recommender     User         @relation(fields: [recommenderId], references: [id])
  npsScore        Int          @map("nps_score") // 0-10
  practiceAreaId  String?      @map("practice_area_id")
  practiceArea    PracticeArea? @relation(fields: [practiceAreaId], references: [id])
  reason          String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("recommendations")
}

model Engagement {
  id             String            @id @default(cuid())
  firmId         String            @map("firm_id")
  firm           Firm              @relation(fields: [firmId], references: [id])
  lawyerId       String?           @map("lawyer_id")
  lawyer         Lawyer?           @relation(fields: [lawyerId], references: [id])
  matterName     String            @map("matter_name")
  matterType     MatterType        @map("matter_type")
  jurisdictionId String?           @map("jurisdiction_id")
  jurisdiction   Jurisdiction?     @relation(fields: [jurisdictionId], references: [id])
  entityName     String?           @map("entity_name") // which SCG entity
  startDate      DateTime          @map("start_date")
  endDate        DateTime?         @map("end_date")
  outcome        EngagementOutcome @default(ONGOING)
  totalFeesUsd   Int?              @map("total_fees_usd") // cents
  notes          String?
  createdById    String            @map("created_by_id")
  createdBy      User              @relation(fields: [createdById], references: [id])
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  @@map("engagements")
}

model RelationshipNote {
  id         String     @id @default(cuid())
  targetType TargetType @map("target_type")
  firmId     String?    @map("firm_id")
  firm       Firm?      @relation(fields: [firmId], references: [id])
  lawyerId   String?    @map("lawyer_id")
  lawyer     Lawyer?    @relation(fields: [lawyerId], references: [id])
  authorId   String     @map("author_id")
  author     User       @relation(fields: [authorId], references: [id])
  content    String
  isPinned   Boolean    @default(false) @map("is_pinned")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  @@map("relationship_notes")
}

model CostBenchmark {
  id             String          @id @default(cuid())
  firmId         String          @map("firm_id")
  firm           Firm            @relation(fields: [firmId], references: [id])
  lawyerId       String?         @map("lawyer_id")
  lawyer         Lawyer?         @relation(fields: [lawyerId], references: [id])
  role           BenchmarkRole
  practiceAreaId String          @map("practice_area_id")
  practiceArea   PracticeArea    @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId String          @map("jurisdiction_id")
  jurisdiction   Jurisdiction    @relation(fields: [jurisdictionId], references: [id])
  hourlyRateUsd  Int             @map("hourly_rate_usd") // cents
  blendedRateUsd Int?            @map("blended_rate_usd") // cents
  fixedFeeUsd    Int?            @map("fixed_fee_usd") // cents
  year           Int
  source         BenchmarkSource
  createdById    String          @map("created_by_id")
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("cost_benchmarks")
}

// ─── User Preferences (Self-Improving Layer) ────────────────────────────────

model UserPreference {
  id                           String @id @default(cuid())
  userId                       String @unique @map("user_id")
  user                         User   @relation(fields: [userId], references: [id])
  weightResponsiveness         Float  @default(1.0) @map("weight_responsiveness")
  weightQuality                Float  @default(1.0) @map("weight_quality")
  weightCommercialAwareness    Float  @default(1.0) @map("weight_commercial_awareness")
  weightValue                  Float  @default(1.0) @map("weight_value")
  weightSubjectMatterExpertise Float  @default(1.0) @map("weight_subject_matter_expertise")
  weightNps                    Float  @default(1.0) @map("weight_nps")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}
