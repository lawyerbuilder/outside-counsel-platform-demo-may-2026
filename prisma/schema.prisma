generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  LAWYER
  MANAGER
  ADMIN
  OUTSIDE_COUNSEL
}

enum FirmType {
  FULL_SERVICE
  BOUTIQUE
  MID_SIZE
  REGIONAL
  ALSP
}

enum LawyerRole {
  PARTNER
  OF_COUNSEL
  ASSOCIATE
  COUNSEL
  OTHER
}

enum RankingPublisher {
  CHAMBERS
  LEGAL500
  BENCHMARK_LITIGATION
  ASIALAW
}

enum LawyerRankingCategory {
  LEADING
  RECOMMENDED
  UP_AND_COMING
  STAR
  RECOGNISED
}

enum TargetType {
  FIRM
  LAWYER
}

enum MatterType {
  LITIGATION
  ARBITRATION
  REGULATORY
  TRANSACTIONAL
  ADVISORY
  IP
  EMPLOYMENT
  OTHER
}

enum EngagementOutcome {
  WON
  LOST
  SETTLED
  ONGOING
  COMPLETED
  OTHER
}

enum BenchmarkRole {
  PARTNER
  OF_COUNSEL
  ASSOCIATE
  PARALEGAL
}

enum BenchmarkSource {
  ACTUAL
  PROPOSED
  MARKET
}

enum PanelStatus {
  ACTIVE
  PROBATION
  EXITED
  PROSPECTIVE
}

enum ComplexityTier {
  COMPLEX
  STANDARD
  ROUTINE
}

enum MatterStatus {
  DRAFT
  INSTRUCTED
  ACTIVE
  ON_HOLD
  CLOSED
  CANCELLED
}

enum FeeType {
  HOURLY
  FIXED
  CAPPED
  PHASED_FIXED
  BLENDED
  COLLAR
  SUCCESS
  HYBRID
}

enum FeeArrangementStatus {
  PROPOSED
  AGREED
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  PARTIAL_APPROVAL
  REJECTED
  APPEALED
  PAID
}

enum FlagCategory {
  BLOCK_BILLING
  PROHIBITED_FEE
  RATE_VIOLATION
  STAFFING_VIOLATION
  DESCRIPTION_VIOLATION
  INTERNAL_COMMS_EXCESS
  EXPENSE_VIOLATION
  LATE_SUBMISSION
  BUDGET_EXCEEDED
  OTHER
}

enum FlagAction {
  REJECT
  REDUCE
  APPROVE_WITH_NOTE
  APPROVE
}

enum RfpStatus {
  DRAFT
  PENDING_APPROVAL
  OPEN
  EVALUATING
  SHORTLISTED
  CLOSED
  CANCELLED
}

enum RfpResponseStatus {
  INVITED
  DECLINED
  SUBMITTED
  SCORED
  SHORTLISTED
  SELECTED
  UNSUCCESSFUL
}

enum ScorecardTier {
  TOP_PERFORMER
  MEETS_EXPECTATIONS
  REQUIRES_IMPROVEMENT
  EXIT_REVIEW
}

enum PanelAction {
  RETAIN_PREFERRED
  RETAIN
  WATCH
  IMPROVEMENT_PLAN
  EXIT_REVIEW
}

enum OnboardingItemStatus {
  PENDING
  COMPLETE
  OVERDUE
  WAIVED
}

enum OcgStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

enum MaturityLevel {
  EARLY
  INTERMEDIATE
  ADVANCED
}

enum AiOutputType {
  INVOICE_REVIEW
  RFP_DRAFT
  RFP_EVALUATION
  SCORECARD
  MATTER_ALLOCATION
  OCG_DRAFT
  OCG_GAP_ANALYSIS
  FEE_RECOMMENDATION
  QBR_PREP
  FIRM_COMPARISON
  INSTRUCTION_AUDIT
  PANEL_HEALTH
  CONVERSATION_GUIDE
  OTHER
}

// ─── Auth / Users ────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  role      UserRole  @default(LAWYER)
  entityId  String?   @map("entity_id")
  entity    Entity?   @relation(fields: [entityId], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  internalRatings    InternalRating[]
  recommendations    Recommendation[]
  engagements        Engagement[]
  relationshipNotes  RelationshipNote[]
  costBenchmarks     CostBenchmark[]
  preference         UserPreference?
  reviewedUpdates    ResearchUpdate[]
  invoiceDecisions   InvoiceDecision[]
  matterFeedbacks    MatterFeedback[]
  scorecards         Scorecard[]
  rfpsCreated        Rfp[]
  rfpEvaluations     RfpEvaluation[]
  aiOutputs          AiOutput[]
  mattersCreated     Matter[]       @relation("MatterCreatedBy")
  mattersSupervised  Matter[]       @relation("MatterSupervisor")
  panelReviews       PanelReview[]
  timesheetUploads   TimesheetUpload[]

  @@map("users")
}

// ─── Reference Data ──────────────────────────────────────────────────────────

model Entity {
  id        String   @id @default(cuid())
  name      String   @unique
  shortName String?  @map("short_name")
  country   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  matters     Matter[]
  invoices    Invoice[]
  costCenters CostCenter[]

  @@map("entities")
}

model CostCenter {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  entityId  String   @map("entity_id")
  entity    Entity   @relation(fields: [entityId], references: [id])
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rfps Rfp[]

  @@map("cost_centers")
}

model PracticeArea {
  id        String        @id @default(cuid())
  name      String        @unique
  slug      String        @unique
  parentId  String?       @map("parent_id")
  parent    PracticeArea? @relation("PracticeAreaHierarchy", fields: [parentId], references: [id])
  children  PracticeArea[] @relation("PracticeAreaHierarchy")
  createdAt DateTime      @default(now()) @map("created_at")

  firmPracticeAreas   FirmPracticeArea[]
  lawyerPracticeAreas LawyerPracticeArea[]
  firmRankings        FirmRanking[]
  lawyerRankings      LawyerRanking[]
  recommendations     Recommendation[]
  costBenchmarks      CostBenchmark[]
  firmCapabilities    FirmCapability[]
  matters             Matter[]
  rfps                Rfp[]
  scorecards          Scorecard[]
  rateCards           RateCard[]

  @@map("practice_areas")
}

model Jurisdiction {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String
  region    String   // APAC, EMEA, AMERICAS, GLOBAL
  createdAt DateTime @default(now()) @map("created_at")

  firmPracticeAreas   FirmPracticeArea[]
  lawyerPracticeAreas LawyerPracticeArea[]
  firmRankings        FirmRanking[]
  lawyerRankings      LawyerRanking[]
  engagements         Engagement[]
  costBenchmarks      CostBenchmark[]
  firmCapabilities    FirmCapability[]
  matters             Matter[]
  rfps                Rfp[]
  scorecards          Scorecard[]
  rateCards           RateCard[]

  @@map("jurisdictions")
}

// ─── Firms ───────────────────────────────────────────────────────────────────

model Firm {
  id           String      @id @default(cuid())
  name         String
  shortName    String?     @map("short_name")
  country      String
  city         String
  website      String?
  firmType     FirmType    @default(FULL_SERVICE) @map("firm_type")
  panelStatus  PanelStatus @default(PROSPECTIVE) @map("panel_status")
  headcount    Int?
  foundedYear  Int?        @map("founded_year")
  parentFirmId String?     @map("parent_firm_id")
  parentFirm   Firm?       @relation("FirmSpinOffs", fields: [parentFirmId], references: [id])
  spinOffs     Firm[]      @relation("FirmSpinOffs")
  isActive     Boolean     @default(true) @map("is_active")
  notes         String?
  internalNotes String?     @map("internal_notes")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  firmLawyers        FirmLawyer[]
  practiceAreas      FirmPracticeArea[]
  rankings           FirmRanking[]
  internalRatings    InternalRating[]
  recommendations    Recommendation[]
  engagements        Engagement[]
  relationshipNotes  RelationshipNote[]
  costBenchmarks     CostBenchmark[]
  researchUpdates    ResearchUpdate[]
  capabilities       FirmCapability[]
  contacts           FirmContact[]
  timekeepers        Timekeeper[]
  rateCards          RateCard[]
  matters            Matter[]
  invoices           Invoice[]
  feeArrangements    FeeArrangement[]
  scorecards         Scorecard[]
  matterFeedbacks    MatterFeedback[]
  rfpInvitations     RfpInvitation[]
  ocgAcknowledgments OcgAcknowledgment[]
  panelReviewFirms   PanelReviewFirm[]
  qbrs               Qbr[]

  @@map("firms")
}

// ─── Lawyers ─────────────────────────────────────────────────────────────────

model Lawyer {
  id                String    @id @default(cuid())
  name              String
  email             String?
  title             String?
  qualificationYear Int?      @map("qualification_year")
  barAdmissions     String?   @map("bar_admissions")
  bio               String?
  linkedInUrl       String?   @map("linkedin_url")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  firmLawyers      FirmLawyer[]
  practiceAreas    LawyerPracticeArea[]
  rankings         LawyerRanking[]
  internalRatings  InternalRating[]
  recommendations  Recommendation[]
  engagements      Engagement[]
  relationshipNotes RelationshipNote[]
  costBenchmarks   CostBenchmark[]
  researchUpdates  ResearchUpdate[]

  @@map("lawyers")
}

// ─── Join Tables ─────────────────────────────────────────────────────────────

model FirmLawyer {
  id        String     @id @default(cuid())
  firmId    String     @map("firm_id")
  firm      Firm       @relation(fields: [firmId], references: [id])
  lawyerId  String     @map("lawyer_id")
  lawyer    Lawyer     @relation(fields: [lawyerId], references: [id])
  role      LawyerRole @default(PARTNER)
  startDate DateTime?  @map("start_date")
  endDate   DateTime?  @map("end_date")
  isCurrent Boolean    @default(true) @map("is_current")
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@unique([firmId, lawyerId, startDate])
  @@map("firm_lawyers")
}

model FirmPracticeArea {
  id             String       @id @default(cuid())
  firmId         String       @map("firm_id")
  firm           Firm         @relation(fields: [firmId], references: [id])
  practiceAreaId String       @map("practice_area_id")
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId String?      @map("jurisdiction_id")
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([firmId, practiceAreaId, jurisdictionId])
  @@map("firm_practice_areas")
}

model LawyerPracticeArea {
  id             String       @id @default(cuid())
  lawyerId       String       @map("lawyer_id")
  lawyer         Lawyer       @relation(fields: [lawyerId], references: [id])
  practiceAreaId String       @map("practice_area_id")
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId String?      @map("jurisdiction_id")
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([lawyerId, practiceAreaId, jurisdictionId])
  @@map("lawyer_practice_areas")
}

// ─── Rankings ────────────────────────────────────────────────────────────────

model RankingSource {
  id           String           @id @default(cuid())
  name         String           @unique
  slug         String           @unique
  publisher    RankingPublisher
  editionYear  Int              @map("edition_year")
  url          String?
  createdAt    DateTime         @default(now()) @map("created_at")

  firmRankings   FirmRanking[]
  lawyerRankings LawyerRanking[]

  @@unique([publisher, editionYear])
  @@map("ranking_sources")
}

model FirmRanking {
  id               String        @id @default(cuid())
  firmId           String        @map("firm_id")
  firm             Firm          @relation(fields: [firmId], references: [id])
  rankingSourceId  String        @map("ranking_source_id")
  rankingSource    RankingSource @relation(fields: [rankingSourceId], references: [id])
  practiceAreaId   String        @map("practice_area_id")
  practiceArea     PracticeArea  @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId   String        @map("jurisdiction_id")
  jurisdiction     Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  band             Int?          // Chambers 1-6
  tier             Int?          // Legal500 1-5
  starRating       Int?          @map("star_rating") // Benchmark 1-5
  editorialExcerpt String?      @map("editorial_excerpt")
  url              String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([firmId, rankingSourceId, practiceAreaId, jurisdictionId])
  @@map("firm_rankings")
}

model LawyerRanking {
  id               String                @id @default(cuid())
  lawyerId         String                @map("lawyer_id")
  lawyer           Lawyer                @relation(fields: [lawyerId], references: [id])
  rankingSourceId  String                @map("ranking_source_id")
  rankingSource    RankingSource         @relation(fields: [rankingSourceId], references: [id])
  practiceAreaId   String                @map("practice_area_id")
  practiceArea     PracticeArea          @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId   String                @map("jurisdiction_id")
  jurisdiction     Jurisdiction          @relation(fields: [jurisdictionId], references: [id])
  category         LawyerRankingCategory
  editorialExcerpt String?              @map("editorial_excerpt")
  url              String?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@unique([lawyerId, rankingSourceId, practiceAreaId, jurisdictionId])
  @@map("lawyer_rankings")
}

// ─── Internal Insights ──────────────────────────────────────────────────────

model InternalRating {
  id                      String     @id @default(cuid())
  targetType              TargetType @map("target_type")
  firmId                  String?    @map("firm_id")
  firm                    Firm?      @relation(fields: [firmId], references: [id])
  lawyerId                String?    @map("lawyer_id")
  lawyer                  Lawyer?    @relation(fields: [lawyerId], references: [id])
  ratedById               String     @map("rated_by_id")
  ratedBy                 User       @relation(fields: [ratedById], references: [id])
  responsiveness          Int        // 1-5
  quality                 Int        // 1-5
  commercialAwareness     Int        @map("commercial_awareness") // 1-5
  value                   Int        // 1-5
  subjectMatterExpertise  Int        @map("subject_matter_expertise") // 1-5
  overallScore            Float      @map("overall_score") // computed weighted avg
  comment                 String?
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")

  @@map("internal_ratings")
}

model Recommendation {
  id              String       @id @default(cuid())
  targetType      TargetType   @map("target_type")
  firmId          String?      @map("firm_id")
  firm            Firm?        @relation(fields: [firmId], references: [id])
  lawyerId        String?      @map("lawyer_id")
  lawyer          Lawyer?      @relation(fields: [lawyerId], references: [id])
  recommenderId   String       @map("recommender_id")
  recommender     User         @relation(fields: [recommenderId], references: [id])
  npsScore        Int          @map("nps_score") // 0-10
  practiceAreaId  String?      @map("practice_area_id")
  practiceArea    PracticeArea? @relation(fields: [practiceAreaId], references: [id])
  reason          String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("recommendations")
}

model Engagement {
  id             String            @id @default(cuid())
  firmId         String            @map("firm_id")
  firm           Firm              @relation(fields: [firmId], references: [id])
  lawyerId       String?           @map("lawyer_id")
  lawyer         Lawyer?           @relation(fields: [lawyerId], references: [id])
  matterNo       String?           @map("matter_no") // e.g. MatterSphere matter number
  matterName     String            @map("matter_name")
  matterType     MatterType        @map("matter_type")
  jurisdictionId String?           @map("jurisdiction_id")
  jurisdiction   Jurisdiction?     @relation(fields: [jurisdictionId], references: [id])
  entityName     String?           @map("entity_name") // which SCG entity
  startDate      DateTime          @map("start_date")
  endDate        DateTime?         @map("end_date")
  outcome        EngagementOutcome @default(ONGOING)
  totalFeesUsd   Int?              @map("total_fees_usd") // cents
  notes          String?
  createdById    String            @map("created_by_id")
  createdBy      User              @relation(fields: [createdById], references: [id])
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  @@map("engagements")
}

model RelationshipNote {
  id         String     @id @default(cuid())
  targetType TargetType @map("target_type")
  firmId     String?    @map("firm_id")
  firm       Firm?      @relation(fields: [firmId], references: [id])
  lawyerId   String?    @map("lawyer_id")
  lawyer     Lawyer?    @relation(fields: [lawyerId], references: [id])
  authorId   String     @map("author_id")
  author     User       @relation(fields: [authorId], references: [id])
  content    String
  isPinned   Boolean    @default(false) @map("is_pinned")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  @@map("relationship_notes")
}

model CostBenchmark {
  id             String          @id @default(cuid())
  firmId         String          @map("firm_id")
  firm           Firm            @relation(fields: [firmId], references: [id])
  lawyerId       String?         @map("lawyer_id")
  lawyer         Lawyer?         @relation(fields: [lawyerId], references: [id])
  role           BenchmarkRole
  practiceAreaId String          @map("practice_area_id")
  practiceArea   PracticeArea    @relation(fields: [practiceAreaId], references: [id])
  jurisdictionId String          @map("jurisdiction_id")
  jurisdiction   Jurisdiction    @relation(fields: [jurisdictionId], references: [id])
  hourlyRateUsd  Int             @map("hourly_rate_usd") // cents
  blendedRateUsd Int?            @map("blended_rate_usd") // cents
  fixedFeeUsd    Int?            @map("fixed_fee_usd") // cents
  year           Int
  source         BenchmarkSource
  createdById    String          @map("created_by_id")
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("cost_benchmarks")
}

// ─── User Preferences (Self-Improving Layer) ────────────────────────────────

model UserPreference {
  id                           String @id @default(cuid())
  userId                       String @unique @map("user_id")
  user                         User   @relation(fields: [userId], references: [id])
  weightResponsiveness         Float  @default(1.0) @map("weight_responsiveness")
  weightQuality                Float  @default(1.0) @map("weight_quality")
  weightCommercialAwareness    Float  @default(1.0) @map("weight_commercial_awareness")
  weightValue                  Float  @default(1.0) @map("weight_value")
  weightSubjectMatterExpertise Float  @default(1.0) @map("weight_subject_matter_expertise")
  weightNps                    Float  @default(1.0) @map("weight_nps")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

// ─── AI Research Queue (Weekly Cron) ──────────────────────────────────────

enum ResearchUpdateStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

enum ResearchUpdateType {
  RANKING_UPDATE
  FIRM_NEWS
  LAWYER_MOVE
  NEW_FIRM
  NEW_LAWYER
  COST_UPDATE
  GENERAL
}

model ResearchUpdate {
  id           String               @id @default(cuid())
  type         ResearchUpdateType
  status       ResearchUpdateStatus @default(PENDING)
  title        String               // Short summary (e.g. "Chambers 2026 rankings released")
  description  String               // AI-generated detail
  rawData      String?              @map("raw_data") // JSON payload from AI research
  targetType   TargetType?          @map("target_type")
  firmId       String?              @map("firm_id")
  firm         Firm?                @relation(fields: [firmId], references: [id])
  lawyerId     String?              @map("lawyer_id")
  lawyer       Lawyer?              @relation(fields: [lawyerId], references: [id])
  source       String?              // URL or source name
  confidence   Float                @default(0.5) // AI confidence 0-1
  reviewedById String?              @map("reviewed_by_id")
  reviewedBy   User?                @relation(fields: [reviewedById], references: [id])
  reviewNote   String?              @map("review_note")
  batchId      String?              @map("batch_id") // Groups updates from same cron run
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@index([status])
  @@index([batchId])
  @@map("research_updates")
}

// ─── Currency & FX ─────────────────────────────────────────────────────────

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  symbol    String
  createdAt DateTime @default(now()) @map("created_at")

  fxRatesFrom FxRate[] @relation("FxFrom")
  fxRatesTo   FxRate[] @relation("FxTo")

  @@map("currencies")
}

model FxRate {
  id             String   @id @default(cuid())
  fromCurrencyId String   @map("from_currency_id")
  fromCurrency   Currency @relation("FxFrom", fields: [fromCurrencyId], references: [id])
  toCurrencyId   String   @map("to_currency_id")
  toCurrency     Currency @relation("FxTo", fields: [toCurrencyId], references: [id])
  rate           Float
  effectiveDate  DateTime @map("effective_date")
  source         String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([fromCurrencyId, toCurrencyId, effectiveDate])
  @@index([effectiveDate])
  @@map("fx_rates")
}

// ─── Firm Capabilities & Contacts (OCP Sub-Panel) ──────────────────────────

model FirmCapability {
  id               String        @id @default(cuid())
  firmId           String        @map("firm_id")
  firm             Firm          @relation(fields: [firmId], references: [id])
  jurisdictionId   String        @map("jurisdiction_id")
  jurisdiction     Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  practiceAreaId   String        @map("practice_area_id")
  practiceArea     PracticeArea  @relation(fields: [practiceAreaId], references: [id])
  complexityTier   ComplexityTier @map("complexity_tier")
  manualPriority   Int           @default(0) @map("manual_priority")
  performanceScore Float?        @map("performance_score")
  rateScore        Float?        @map("rate_score")
  rankingScore     Float?        @map("ranking_score")
  overallScore     Float?        @map("overall_score")
  notes            String?
  isActive         Boolean       @default(true) @map("is_active")
  lastReviewedAt   DateTime?     @map("last_reviewed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@unique([firmId, jurisdictionId, practiceAreaId, complexityTier])
  @@index([jurisdictionId, practiceAreaId, complexityTier, isActive])
  @@map("firm_capabilities")
}

model FirmContact {
  id        String   @id @default(cuid())
  firmId    String   @map("firm_id")
  firm      Firm     @relation(fields: [firmId], references: [id])
  name      String
  email     String?
  phone     String?
  role      String
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("firm_contacts")
}

model Timekeeper {
  id               String    @id @default(cuid())
  firmId           String    @map("firm_id")
  firm             Firm      @relation(fields: [firmId], references: [id])
  name             String
